bpnn = MLPRegressor(
 hidden_layer_sizes=(12, 8),
 activation="tanh",
 solver="lbfgs",
 max_iter=20000,
 random_state=7
)
bpnn.fit(X_scaled, y_scaled)
def predict_by_bpnn(x_input):
 x_input = np.asarray(x_input, dtype=float)
 if x_input.ndim == 1:
  x_input = x_input.reshape(1, -1)
 x_input_scaled = x_scaler.transform(x_input)
 y_pred_scaled = bpnn.predict(x_input_scaled)
 y_pred = y_scaler.inverse_transform(y_pred_scaled)
 return y_pred
