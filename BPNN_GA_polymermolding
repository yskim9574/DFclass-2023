# 3. 목적함수 설정
y_min = y.min(axis=0)
y_max = y.max(axis=0)
def objective(population):
 pred = predict_by_bpnn(population)
 warpage = pred[:, 0]
 shrinkage = pred[:, 1]
 warpage_norm = (warpage - y_min[0]) / (y_max[0] - y_min[0])
 shrinkage_norm = (shrinkage - y_min[1]) / (y_max[1] - y_min[1])
 return warpage_norm + shrinkage_norm
# 4. GA 설정
bounds = np.array([
 [25, 45],
 [200, 240],
 [1, 6],
 [80, 160],
 [1, 5],
 [20, 40],
], dtype=float)
def run_ga(seed=42, n_population=100, n_generation=200, n_elite=10):
 rng = np.random.default_rng(seed)
 n_var = bounds.shape[0]
 lower = bounds[:, 0]
 upper = bounds[:, 1]
 population = lower + rng.random((n_population, n_var)) * (upper - lower)
 for gen in range(n_generation):
  score = objective(population)
  order = np.argsort(score)
  population = population[order]
  score = score[order]
  new_population = np.empty_like(population)
  new_population[:n_elite] = population[:n_elite]
  for i in range(n_elite, n_population):
   cand1 = rng.integers(0, n_population, size=3)
   parent1 = population[cand1[np.argmin(score[cand1])]]
   cand2 = rng.integers(0, n_population, size=3)
   parent2 = population[cand2[np.argmin(score[cand2])]]
   alpha = rng.random(n_var)
   child = alpha * parent1 + (1 - alpha) * parent2
   mutation = rng.normal(0, 0.015 * (upper - lower), size=n_var)
   child = child + mutation
   if rng.random() < 0.2:
    j = rng.integers(0, n_var)
    child[ j] = lower[ j] + rng.random() * (upper[ j] - lower[ j])
   # 범위 제한
   child = np.clip(child, lower, upper)
   new_population[i] = child
  population = new_population
 final_score = objective(population)
 best_index = np.argmin(final_score)
 best_x = population[best_index]
 best_y = predict_by_bpnn(best_x)[0]
 best_score = final_score[best_index]
 return best_x, best_y, best_score
# 5. GA-BPNN 최적화 실행
