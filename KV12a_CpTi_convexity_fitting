# 7. Stress state helper
# ------------------------------------------------------------
def uniaxial_stress_state(deg, sign=+1.0):
    """
    sign = +1 : tension
    sign = -1 : compression
    """
 
    th = np.radians(deg)
    c = np.cos(th)
    s = np.sin(th)
 
    sx = sign * c**2
    sy = sign * s**2
    sxy = sign * s * c
 
    return sx, sy, sxy
 
 
# ------------------------------------------------------------
# 8. Prediction functions
# ------------------------------------------------------------
def predict_sigma_uniaxial(raw, deg, sign=+1.0):
    sx, sy, sxy = uniaxial_stress_state(deg, sign=sign)
 
    phi, _, _, _ = get_phi_and_derivatives(raw, sx, sy, sxy)
 
    if phi <= 0 or np.isnan(phi):
        return np.nan
 
    return (phi / k12) ** (-1.0 / 12.0)
 
 
def predict_sigma_theta(raw, deg):
    return predict_sigma_uniaxial(raw, deg, sign=+1.0)
 
 
def predict_sigma_compression(raw, deg):
    return predict_sigma_uniaxial(raw, deg, sign=-1.0)
 
 
def predict_r_theta(raw, deg):
    sx, sy, sxy = uniaxial_stress_state(deg, sign=+1.0)
 
    _, dfx, dfy, dfxy = get_phi_and_derivatives(raw, sx, sy, sxy)
 
    th = np.radians(deg)
    c = np.cos(th)
    s = np.sin(th)
 
    numerator = dfx * s**2 + dfy * c**2 - dfxy * s * c
    denominator = dfx + dfy
 
    if np.abs(denominator) < 1.0e-14:
        return np.nan
 
    return -numerator / denominator
 
 
def predict_sigma_b(raw):
    phi, _, _, _ = get_phi_and_derivatives(raw, 1.0, 1.0, 0.0)
 
    if phi <= 0 or np.isnan(phi):
        return np.nan
 
    return (phi / k12) ** (-1.0 / 12.0)
 
 
def predict_r_b(raw):
    _, dfx, dfy, _ = get_phi_and_derivatives(raw, 1.0, 1.0, 0.0)
 
    if np.abs(dfx) < 1.0e-14:
        return np.nan
 
    return dfy / dfx
 
 
