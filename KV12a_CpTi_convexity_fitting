# 4. Parameter transformation
# ------------------------------------------------------------
def unpack_raw_params(raw):
    """
    raw parameter를 실제 항복함수 parameter로 변환.
 
    목적:
    1) alpha > 0 강제
    2) beta가 너무 커지지 않도록 제한
 
    raw =
    [a1,a2,a3,a4,b1,b2,b3,b4,b5,b10, alpha_raw, beta_raw]
    """
 
    a1, a2, a3, a4 = raw[0:4]
    b1, b2, b3, b4, b5, b10 = raw[4:10]
 
    # alpha > 0
    alpha = np.exp(raw[10])
 
    # beta 제한
    # eta는 -1~1 사이
    eta = np.tanh(raw[11])
 
    # 충분조건 기반 beta limit
    beta_lim = 4.0 * alpha**0.25 / (3.0**0.75)
 
    beta = BETA_SAFETY * eta * beta_lim
 
    return np.array([
        a1, a2, a3, a4,
        b1, b2, b3, b4, b5, b10,
        alpha, beta
    ])
 
 
def make_initial_raw_params(initial_params):
    """
    기존 초기값 [a1,...,alpha,beta]를 raw parameter로 변환합니다.
    """
 
    raw = np.zeros_like(np.array(initial_params, dtype=float))
 
    raw[0:10] = initial_params[0:10]
 
    alpha0 = initial_params[10]
    beta0 = initial_params[11]
 
    # alpha_raw = log(alpha)
    raw[10] = np.log(max(alpha0, 1.0e-8))
 
    beta_lim0 = 4.0 * alpha0**0.25 / (3.0**0.75)
 
    eta0 = beta0 / (BETA_SAFETY * beta_lim0)
 
    # tanh 역함수에 들어갈 수 있도록 제한
    eta0 = np.clip(eta0, -0.95, 0.95)
 
    raw[11] = np.arctanh(eta0)
 
    return raw
 
 
# ------------------------------------------------------------
# 5. J2, J3 계산 (벡터화 가능)
# ------------------------------------------------------------
def get_j2_j3(params, sx, sy, sxy):
    a1, a2, a3, a4 = params[0:4]
    b1, b2, b3, b4, b5, b10 = params[4:10]
 
    j20 = (
        (1.0 / 6.0)
        * ((a1 + a3) * sx**2
           + (a1 + a2) * sy**2
           - 2.0 * a1 * sx * sy)
        + a4 * sxy**2
    )
 
    j30 = (
        (1.0 / 27.0) * ((b1 + b2) * sx**3
                        + (b3 + b4) * sy**3)
        - (1.0 / 9.0) * (b1 * sx + b4 * sy) * sx * sy
        + (1.0 / 3.0)
        * (b5 * sy + (2.0 * b10 - b5) * sx)
        * sxy**2
    )
 
    return j20, j30
 
 
def get_phi_values(params, sx, sy, sxy):
    """
    phi만 벡터화하여 계산합니다 (penalty 계산용, 미분 불필요).
    sx, sy, sxy는 스칼라 또는 numpy 배열.
    """
    alpha, beta = params[10], params[11]
    j20, j30 = get_j2_j3(params, sx, sy, sxy)
    abs_j2 = np.abs(j20)
    return j20**6 + alpha * j30**4 + beta * abs_j2**4.5 * j30
 
 
def sigma_eq_values(params, sx, sy, sxy):
    """
    등가응력 sigma_eq = (phi/k12)^(1/12), 벡터화.
    phi <= 0 인 곳은 NaN.
    """
    phi = get_phi_values(params, sx, sy, sxy)
    se = np.full_like(np.asarray(phi, dtype=float), np.nan)
    ok = np.isfinite(phi) & (phi > 0.0)
    se[ok] = (phi[ok] / k12) ** (1.0 / 12.0)
    return se
 
 
# ------------------------------------------------------------
# 6. 비대칭 항복함수와 미분값
# ------------------------------------------------------------
def get_phi_and_derivatives_from_params(params, sx, sy, sxy):
    """
    params는 실제 parameter입니다.
    """
 
    a1, a2, a3, a4 = params[0:4]
    b1, b2, b3, b4, b5, b10 = params[4:10]
    alpha, beta = params[10], params[11]
 
    j20, j30 = get_j2_j3(params, sx, sy, sxy)
 
    p_asym = 4.5
    abs_j2 = np.abs(j20)
 
    phi = (
        j20**6
        + alpha * j30**4
        + beta * abs_j2**p_asym * j30
    )
 
    # dJ2/dsigma
    dj2_dsx = ((a1 + a3) / 3.0) * sx - (a1 / 3.0) * sy
    dj2_dsy = ((a1 + a2) / 3.0) * sy - (a1 / 3.0) * sx
    dj2_dsxy = 2.0 * a4 * sxy
 
    # dJ3/dsigma
    dj3_dsx = (
        (b1 / 9.0) * (sx - sy) ** 2
        + (b2 / 9.0) * sx**2
        - ((b1 + b4) / 9.0) * sy**2
        + ((2.0 * b10 - b5) / 3.0) * sxy**2
    )
 
    dj3_dsy = (
        (b4 / 9.0) * (sy - sx) ** 2
        + (b3 / 9.0) * sy**2
        - ((b1 + b4) / 9.0) * sx**2
        + (b5 / 3.0) * sxy**2
    )
 
    dj3_dsxy = (
        (2.0 / 3.0)
        * sxy
        * (b5 * sy + (2.0 * b10 - b5) * sx)
    )
 
    if abs_j2 < 1.0e-14:
        sign_j2 = 0.0
    else:
        sign_j2 = np.sign(j20)
 
    # dphi/dJ2
    A = (
        6.0 * j20**5
        + beta * p_asym * abs_j2**(p_asym - 1.0) * sign_j2 * j30
    )
 
    # dphi/dJ3
    B = (
        4.0 * alpha * j30**3
        + beta * abs_j2**p_asym
    )
 
    df_dsx = A * dj2_dsx + B * dj3_dsx
    df_dsy = A * dj2_dsy + B * dj3_dsy
    df_dsxy = A * dj2_dsxy + B * dj3_dsxy
 
    return phi, df_dsx, df_dsy, df_dsxy
 
 
def get_phi_and_derivatives(raw, sx, sy, sxy):
    params = unpack_raw_params(raw)
    return get_phi_and_derivatives_from_params(params, sx, sy, sxy)
 
 
