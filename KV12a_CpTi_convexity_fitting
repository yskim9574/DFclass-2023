# 9. 중심 단면(central section)의 radial distance와 곡률
# ------------------------------------------------------------
# (u, v)는 (sx, sy, sxy) 응력공간에서 단면을 정의하는 두 방향벡터.
# 단면 위에서 s(theta) = cos(theta)*u + sin(theta)*v 방향의
# 항복점까지 거리 rho(theta)를 구하고 극좌표 볼록조건을 검사.
#
# 볼록조건: rho^2 + 2*rho'^2 - rho*rho'' >= 0
# (원점을 지나는 모든 2차원 단면이 볼록이면 곡면 전체가 볼록)
#
# SECTION_PLANES = (u, v, 검사각도수, 상대가중치, 이름)
SECTION_PLANES = [
    (np.array([1.0, 0.0, 0.0]), np.array([0.0, 1.0, 0.0]),
     721, 1.0, 'sx-sy'),
    (np.array([1.0, 0.0, 0.0]), np.array([0.0, 0.0, 1.0]),
     241, 0.5, 'sx-sxy'),
    (np.array([0.0, 1.0, 0.0]), np.array([0.0, 0.0, 1.0]),
     241, 0.5, 'sy-sxy'),
    (np.array([1.0, 1.0, 0.0]) / np.sqrt(2.0), np.array([0.0, 0.0, 1.0]),
     241, 0.5, 'biax-sxy'),
    (np.array([1.0, -1.0, 0.0]) / np.sqrt(2.0), np.array([0.0, 0.0, 1.0]),
     241, 0.5, 'shear-sxy'),
]
 
 
def radial_rho_section(params, u, v, angs):
    """
    단면 (u, v) 위에서 방향각 angs에 대한 radial yield distance rho.
    phi <= 0이면 NaN (열린 곡면).
    """
    c = np.cos(angs)
    s = np.sin(angs)
 
    sx = c * u[0] + s * v[0]
    sy = c * u[1] + s * v[1]
    sxy = c * u[2] + s * v[2]
 
    phi = get_phi_values(params, sx, sy, sxy)
 
    rho = np.full_like(phi, np.nan)
    ok = np.isfinite(phi) & (phi > 0.0)
    rho[ok] = (phi[ok] / k12) ** (-1.0 / 12.0)
 
    return rho
 
 
def section_curvature(params, u, v, n_ang):
    """
    단면 위 정규화 곡률 측정값을 돌려줍니다.
 
        curv_n = (rho^2 + 2*rho'^2 - rho*rho'') / rho^2
 
    원이면 curv_n = 1, 평탄부에서 0, 오목부에서 음수.
    rho 계산 실패 시 curv_n = None.
    """
    angs = np.linspace(0.0, 2.0 * np.pi, n_ang, endpoint=False)
    dth = angs[1] - angs[0]
 
    rho = radial_rho_section(params, u, v, angs)
 
    if np.any(~np.isfinite(rho)):
        return angs, rho, None
 
    rho_p = np.roll(rho, -1)
    rho_m = np.roll(rho, 1)
 
    rho_prime = (rho_p - rho_m) / (2.0 * dth)
    rho_double = (rho_p - 2.0 * rho + rho_m) / dth**2
 
    curv = rho**2 + 2.0 * rho_prime**2 - rho * rho_double
 
    return angs, rho, curv / rho**2
 
 
def section_convexity_penalty(params, u, v, n_ang, weight, margin_rel):
    """
    정규화 곡률이 margin_rel보다 작아지면 점별로 penalty를 부여.
 
    기존 코드와의 차이:
      - margin_rel > 0 : 곡률이 0에 닿기 전에 미리 밀어냄 (buffer)
      - 점별 정규화   : 국소 위반이 평균에 희석되지 않음
    """
    angs, rho, curv_n = section_curvature(params, u, v, n_ang)
 
    if curv_n is None:
        return np.full(n_ang, 1.0e3)
 
    pen = np.maximum(0.0, margin_rel - curv_n)
 
    return np.sqrt(weight) * pen
 
 
# ------------------------------------------------------------
# 10. Closure and positivity penalties (벡터화)
# ------------------------------------------------------------
def closure_penalty(params, n_ang=181, eps=1.0e-8, weight=5.0):
    """
    항복곡면이 열리지 않도록 phi(direction) > 0을 요구.
    """
    angs = np.linspace(0.0, 2.0 * np.pi, n_ang, endpoint=False)
    sx = np.cos(angs)
    sy = np.sin(angs)
    sxy = np.zeros_like(angs)
 
    phi = get_phi_values(params, sx, sy, sxy)
 
    res = np.zeros(n_ang)
    bad = ~np.isfinite(phi)
    small = (~bad) & (phi < eps)
 
    res[bad] = 1.0e3
    res[small] = np.sqrt(weight) * (eps - phi[small]) / eps
 
    return res
 
 
def j2_positive_penalty(params, n_ang=181, eps=1.0e-8, weight=5.0):
    """
    J2^0가 모든 방향에서 양수가 되도록 하는 penalty입니다.
    """
    angs = np.linspace(0.0, 2.0 * np.pi, n_ang, endpoint=False)
    sx = np.concatenate([np.cos(angs), [0.0]])
    sy = np.concatenate([np.sin(angs), [0.0]])
    sxy = np.concatenate([np.zeros(n_ang), [1.0]])  # pure shear 방향 포함
 
    j20, _ = get_j2_j3(params, sx, sy, sxy)
 
    res = np.zeros(n_ang + 1)
    bad = ~np.isfinite(j20)
    small = (~bad) & (j20 < eps)
 
    res[bad] = 1.0e3
    res[small] = np.sqrt(weight) * (eps - j20[small]) / eps
 
    return res
 
 
