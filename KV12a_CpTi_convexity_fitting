# 12. 최적화 후 볼록성 검증 함수
# ------------------------------------------------------------
def verify_sections(params, n_fine=N_VERIFY):
    """
    모든 단면에서 정규화 곡률의 최소값과 발생 위치를 구합니다.
    """
    report = []
    worst_val = np.inf
    worst_plane = None
    worst_deg = np.nan
 
    for (u, v, _n, _w, name) in SECTION_PLANES:
        angs, rho, curv_n = section_curvature(params, u, v, n_fine)
 
        if curv_n is None:
            report.append((name, -np.inf, np.nan))
            worst_val = -np.inf
            worst_plane = name
            continue
 
        i = int(np.argmin(curv_n))
        report.append((name, curv_n[i], np.degrees(angs[i])))
 
        if curv_n[i] < worst_val:
            worst_val = curv_n[i]
            worst_plane = name
            worst_deg = np.degrees(angs[i])
 
    return worst_val, worst_plane, worst_deg, report
 
 
def hessian_convexity_check(params, n_th=72, n_ps=35, h=1.0e-4):
    """
    등가응력 sigma_eq = (phi/k12)^(1/12)의 Hessian 최소 고유값을
    항복곡면 위 표본점에서 수치적으로 검사 (전 응력공간 검증).
 
    sigma_eq는 1차 동차함수이므로 radial 방향 고유값은 항상 0이며,
    나머지 고유값이 모두 >= 0이면 볼록
    반환값은 무차원화된 최소 고유값 lam_min * ||sigma|| 임.
    """
    th = np.linspace(0.0, 2.0 * np.pi, n_th, endpoint=False)
    ps = np.linspace(-0.5 * np.pi, 0.5 * np.pi, n_ps + 2)[1:-1]
    TH, PS = np.meshgrid(th, ps)
 
    dx = (np.cos(PS) * np.cos(TH)).ravel()
    dy = (np.cos(PS) * np.sin(TH)).ravel()
    dz = np.sin(PS).ravel()
 
    phi = get_phi_values(params, dx, dy, dz)
    ok = np.isfinite(phi) & (phi > 0.0)
 
    rho = (phi[ok] / k12) ** (-1.0 / 12.0)
    X = np.stack([dx[ok] * rho, dy[ok] * rho, dz[ok] * rho], axis=1)
    n_pts = X.shape[0]
 
    norms = np.linalg.norm(X, axis=1)
    hs = h * np.maximum(1.0, norms)
 
    def f(P):
        return sigma_eq_values(params, P[:, 0], P[:, 1], P[:, 2])
 
    E = np.eye(3)
    H = np.zeros((n_pts, 3, 3))
    f0 = f(X)
 
    for i in range(3):
        fp = f(X + hs[:, None] * E[i])
        fm = f(X - hs[:, None] * E[i])
        H[:, i, i] = (fp - 2.0 * f0 + fm) / hs**2
 
        for j in range(i + 1, 3):
            fpp = f(X + hs[:, None] * (E[i] + E[j]))
            fpm = f(X + hs[:, None] * (E[i] - E[j]))
            fmp = f(X - hs[:, None] * (E[i] - E[j]))
            fmm = f(X - hs[:, None] * (E[i] + E[j]))
            hij = (fpp - fpm - fmp + fmm) / (4.0 * hs**2)
            H[:, i, j] = hij
            H[:, j, i] = hij
 
    finite = np.all(np.isfinite(H.reshape(n_pts, -1)), axis=1)
    H = H[finite]
    norms = norms[finite]
    X = X[finite]
 
    eig = np.linalg.eigvalsh(H)          # 오름차순
    lam_min = eig[:, 0] * norms          # 무차원화
 
    k = int(np.argmin(lam_min))
    return lam_min[k], X[k]
 
 
def convex_hull_check(params, n=4001):
    """
    sx-sy 단면의 locus 점들과 그 convex hull 사이의 최대 내측 편차를
    계산. 편차가 ~1e-12 이하이면 locus는 자기 자신의 convex hull과
    일치하며, 이는 곡면이 볼록하다는 결정적(수학적) 증거임.
 
    주의: 곡률이 0에 가까운 '평탄'한 구간은 눈에는 오목처럼 보일 수
    있으나, 평탄(곡률 >= 0)과 오목(곡률 < 0)은 엄연히 다름.
    """
    from scipy.spatial import ConvexHull
 
    u, v = SECTION_PLANES[0][0], SECTION_PLANES[0][1]
    angs, rho, _curv = section_curvature(params, u, v, n)
 
    if np.any(~np.isfinite(rho)):
        return np.inf, None, None
 
    pts = np.stack([rho * np.cos(angs), rho * np.sin(angs)], axis=1)
    hull = ConvexHull(pts)
 
    # hull.equations: A x + b <= 0 (내부). 경계까지의 내측 거리:
    d_inside = -(pts @ hull.equations[:, :2].T
                 + hull.equations[:, 2]).max(axis=1)
 
    return d_inside.max(), pts, hull
 
 
