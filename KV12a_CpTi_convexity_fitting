# 11. Objective function
# ------------------------------------------------------------
def objective(raw):
    """
    실험값 fitting residual + 물리적 제약 penalty.
    residual 벡터 길이는 항상 동일하게 유지됩니다.
    """
    params = unpack_raw_params(raw)
 
    # fitting weights
    w_sigma = 20.0
    w_r = 1.0
    w_sigma_b = 10.0
    w_r_b = 1.0
    w_comp = 15.0
 
    pred_sigma = np.array([
        predict_sigma_theta(raw, deg) for deg in angles_deg
    ])
 
    pred_r = np.array([
        predict_r_theta(raw, deg) for deg in angles_deg
    ])
 
    pred_sb = predict_sigma_b(raw)
    pred_rb = predict_r_b(raw)
 
    res_sigma = np.sqrt(w_sigma) * (1.0 - pred_sigma / exp_sigma)
    res_r = np.sqrt(w_r) * (1.0 - pred_r / exp_r)
    res_sigma_b = np.array([np.sqrt(w_sigma_b) * (1.0 - pred_sb / exp_sigma_b)])
    res_r_b = np.array([np.sqrt(w_r_b) * (1.0 - pred_rb / exp_r_b)])
 
    residuals = [res_sigma, res_r, res_sigma_b, res_r_b]
 
    # 압축 데이터가 있으면 추가
    if use_compression_data:
        pred_comp = np.array([
            predict_sigma_compression(raw, deg)
            for deg in comp_angles_deg
        ])
        res_comp = np.sqrt(w_comp) * (1.0 - pred_comp / exp_sigma_c)
        residuals.append(res_comp)
 
    # 2축 locus 실험점이 있으면 추가
    if use_locus_data:
        px = exp_locus_points[:, 0]
        py = exp_locus_points[:, 1]
        rr = np.hypot(px, py)
        ux, uy = px / rr, py / rr
        phi_u = get_phi_values(params, ux, uy, np.zeros_like(ux))
        rho_pred = np.where(
            phi_u > 0.0,
            (np.maximum(phi_u, 1.0e-300) / k12) ** (-1.0 / 12.0),
            np.nan
        )
        residuals.append(np.sqrt(w_locus) * (1.0 - rho_pred / rr))
 
    # 닫힌 항복곡면 penalty
    residuals.append(closure_penalty(params, n_ang=181, eps=1.0e-8, weight=2.0))
 
    # J2^0 positive penalty
    residuals.append(j2_positive_penalty(params, n_ang=181, eps=1.0e-8, weight=2.0))
 
    # 볼록성 penalty: 전단 포함 5개 중심 단면
    for (u, v, n_ang, w_rel, _name) in SECTION_PLANES:
        residuals.append(
            section_convexity_penalty(
                params, u, v, n_ang,
                weight=CONV['weight'] * w_rel,
                margin_rel=CONV['margin_rel']
            )
        )
 
    res_all = np.concatenate(residuals)
 
    # NaN/Inf -> 큰 상수로 치환 (residual 길이를 항상 고정)
    return np.nan_to_num(res_all, nan=1.0e3, posinf=1.0e3, neginf=-1.0e3)
 
 
