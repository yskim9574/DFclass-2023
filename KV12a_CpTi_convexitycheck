def get_yield_constant():
    """
  
    """

    if 'k12' in globals():
        return k12
    elif 'k8' in globals():
        return k8
    else:
        raise ValueError("Neither k12 nor k8 is defined.")


def midpoint_convexity_check(raw, n_ang=181, step=4, tol=1.0e-5, print_result=True):
    """
   
    """

    k_const = get_yield_constant()

    angs = np.linspace(0.0, 2.0*np.pi, n_ang, endpoint=False)

    pts = []

    for th in angs:
        rho = radial_yield_stress(raw, th)

        if np.isnan(rho) or np.isinf(rho):
            print("Midpoint check failed: rho contains NaN or Inf.")
            return False, None

        sx = rho * np.cos(th)
        sy = rho * np.sin(th)

        pts.append([sx, sy])

    pts = np.array(pts)

    idx = np.arange(0, n_ang, step)

    max_violation = 0.0
    worst_pair = None
    worst_midpoint = None

    violations = []

    for ii in range(len(idx)):
        for jj in range(ii + 1, len(idx)):

            i = idx[ii]
            j = idx[jj]

            p_mid = 0.5 * (pts[i] + pts[j])

            phi_mid, _, _, _ = get_phi_and_derivatives(
                raw,
                p_mid[0],
                p_mid[1],
                0.0
            )

            violation = phi_mid / k_const - 1.0

            if violation > tol:
                violations.append([p_mid[0], p_mid[1], violation])

                if violation > max_violation:
                    max_violation = violation
                    worst_pair = (i, j)
                    worst_midpoint = p_mid.copy()

    is_convex = len(violations) == 0

    if print_result:
        print("\n=== Midpoint Convexity Check ===")
        print(f"Number of checked points on yield locus = {len(idx)}")
        print(f"Number of checked pairs                 = {len(idx)*(len(idx)-1)//2}")
        print(f"Tolerance                               = {tol:.2e}")

        if is_convex:
            print("Result: Convex in sigma_x - sigma_y plane.")
        else:
            print("Result: Non-convex region detected.")
            print(f"Number of violations = {len(violations)}")
            print(f"Maximum violation    = {max_violation:.6e}")
            print(f"Worst midpoint       = ({worst_midpoint[0]:.4f}, {worst_midpoint[1]:.4f})")
            print(f"Worst pair indices   = {worst_pair}")

    return is_convex, {
        "yield_points": pts,
        "violations": np.array(violations),
        "max_violation": max_violation,
        "worst_pair": worst_pair,
        "worst_midpoint": worst_midpoint
    }



