# 1) Polar curvature-based convexity check
def check_polar_convexity(raw, n_ang=721, tol=1.0e-6, print_result=True):
    """
   

    Convex condition:
        rho^2 + 2*rho_prime^2 - rho*rho_double_prime >= 0

   
    """

    angs = np.linspace(0.0, 2.0*np.pi, n_ang, endpoint=False)
    dth = angs[1] - angs[0]

    rho = np.array([
        radial_yield_stress(raw, th) for th in angs
    ])

    if np.any(np.isnan(rho)) or np.any(np.isinf(rho)):
        print("Convexity check failed: rho contains NaN or Inf.")
        return False, None

    rho_p = np.roll(rho, -1)
    rho_m = np.roll(rho, 1)

    rho_prime = (rho_p - rho_m) / (2.0*dth)
    rho_double = (rho_p - 2.0*rho + rho_m) / (dth**2)

    convex_measure = rho**2 + 2.0*rho_prime**2 - rho*rho_double

    min_val = np.min(convex_measure)
    min_idx = np.argmin(convex_measure)
    min_angle_deg = np.degrees(angs[min_idx])

    is_convex = min_val >= -tol

    if print_result:
        print("\n=== Polar Convexity Check ===")
        print(f"Minimum convexity measure = {min_val:.6e}")
        print(f"Minimum angle             = {min_angle_deg:.2f} deg")
        print(f"Tolerance                 = {tol:.2e}")

        if is_convex:
            print("Result: Convex in sigma_x - sigma_y plane.")
        else:
            print("Result: Non-convex region detected.")

    return is_convex, {
        "angles_rad": angs,
        "rho": rho,
        "convex_measure": convex_measure,
        "min_value": min_val,
        "min_angle_deg": min_angle_deg
    }



is_convex, convex_info = check_polar_convexity(
