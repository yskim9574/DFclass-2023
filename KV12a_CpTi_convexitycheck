# ------------------------------------------------------------
# 3. Constants
# ------------------------------------------------------------
k12 = (1.0 / (3.0)**(1/2)) ** 6


# ------------------------------------------------------------
# 4. Parameter transformation
# ------------------------------------------------------------
def unpack_raw_params(raw):
    """
    raw parameter를 실제 항복함수 parameter로 변환합니다.

    목적:
    1) alpha > 0 강제
    2) beta가 너무 커지지 않도록 제한

    raw =
    [a1,a2,a3,a4,b1,b2,b3,b4,b5,b10, alpha_raw, beta_raw]
    """

    a1, a2, a3, a4 = raw[0:4]
    b1, b2, b3, b4, b5, b10 = raw[4:10]

    # alpha > 0
    alpha = np.exp(raw[10])

    # beta 제한
    # eta는 -1~1 사이
    eta = np.tanh(raw[11])

    # 충분조건 기반 beta limit
    beta_lim = 4.0 * alpha**0.25 / (3.0**0.75)

    # 안전계수: 0.6-0.95
    beta = 0.95 * eta * beta_lim


    return np.array([
        a1, a2, a3, a4,
        b1, b2, b3, b4, b5, b10,
        alpha, beta
    ])


def make_initial_raw_params(initial_params):
    """
    기존 초기값 [a1,...,alpha,beta]를 raw parameter로 변환합니다.
    """

    raw = np.zeros_like(np.array(initial_params, dtype=float))

    raw[0:10] = initial_params[0:10]

    alpha0 = initial_params[10]
    beta0 = initial_params[11]

    # alpha_raw = log(alpha)
    raw[10] = np.log(max(alpha0, 1.0e-8))

    beta_lim0 = 4.0 * alpha0**0.25 / (3.0**0.75)

    eta0 = beta0 / (0.95 * beta_lim0)

    # tanh 역함수에 들어갈 수 있도록 제한
    eta0 = np.clip(eta0, -0.95, 0.95)

    raw[11] = np.arctanh(eta0)

    return raw


# ------------------------------------------------------------
# 5. J2, J3 계산
# ------------------------------------------------------------
def get_j2_j3(params, sx, sy, sxy):
    a1, a2, a3, a4 = params[0:4]
    b1, b2, b3, b4, b5, b10 = params[4:10]

    j20 = (
        (1.0 / 6.0)
        * ((a1 + a3) * sx**2
           + (a1 + a2) * sy**2
           - 2.0 * a1 * sx * sy)
        + a4 * sxy**2
    )

    j30 = (
        (1.0 / 27.0) * ((b1 + b2) * sx**3
                        + (b3 + b4) * sy**3)
        - (1.0 / 9.0) * (b1 * sx + b4 * sy) * sx * sy
        + (1.0 / 3.0)
        * (b5 * sy + (2.0 * b10 - b5) * sx)
        * sxy**2
    )

    return j20, j30


# ------------------------------------------------------------
# 6. 비대칭 항복함수와 미분값
# ------------------------------------------------------------
def get_phi_and_derivatives_from_params(params, sx, sy, sxy):
    """
    params는 실제 parameter입니다.
    """

    a1, a2, a3, a4 = params[0:4]
    b1, b2, b3, b4, b5, b10 = params[4:10]
    alpha, beta = params[10], params[11]

    j20, j30 = get_j2_j3(params, sx, sy, sxy)

    p_asym = 4.5
    abs_j2 = np.abs(j20)

    phi = (
        j20**6
        + alpha * j30**4
        + beta * abs_j2**p_asym * j30
    )

    # dJ2/dsigma
    dj2_dsx = ((a1 + a3) / 3.0) * sx - (a1 / 3.0) * sy
    dj2_dsy = ((a1 + a2) / 3.0) * sy - (a1 / 3.0) * sx
    dj2_dsxy = 2.0 * a4 * sxy

    # dJ3/dsigma
    dj3_dsx = (
        (b1 / 9.0) * (sx - sy) ** 2
        + (b2 / 9.0) * sx**2
        - ((b1 + b4) / 9.0) * sy**2
        + ((2.0 * b10 - b5) / 3.0) * sxy**2
    )

    dj3_dsy = (
        (b4 / 9.0) * (sy - sx) ** 2
        + (b3 / 9.0) * sy**2
        - ((b1 + b4) / 9.0) * sx**2
        + (b5 / 3.0) * sxy**2
    )

    dj3_dsxy = (
        (2.0 / 3.0)
        * sxy
        * (b5 * sy + (2.0 * b10 - b5) * sx)
    )

    if abs_j2 < 1.0e-14:
        sign_j2 = 0.0
    else:
        sign_j2 = np.sign(j20)

    # dphi/dJ2
    A = (
        6.0 * j20**5
        + beta * p_asym * abs_j2**(p_asym - 1.0) * sign_j2 * j30
    )

    # dphi/dJ3
    B = (
        4.0 * alpha * j30**3
        + beta * abs_j2**p_asym
    )

    df_dsx = A * dj2_dsx + B * dj3_dsx
    df_dsy = A * dj2_dsy + B * dj3_dsy
    df_dsxy = A * dj2_dsxy + B * dj3_dsxy

    return phi, df_dsx, df_dsy, df_dsxy


def get_phi_and_derivatives(raw, sx, sy, sxy):
    params = unpack_raw_params(raw)
    return get_phi_and_derivatives_from_params(params, sx, sy, sxy)


# ------------------------------------------------------------
# 7. Stress state helper
# ------------------------------------------------------------
def uniaxial_stress_state(deg, sign=+1.0):
    """
    sign = +1 : tension
    sign = -1 : compression

    theta 방향 단축응력 상태:
    sigma_x  = sign*cos^2(theta)
    sigma_y  = sign*sin^2(theta)
    tau_xy   = sign*sin(theta)*cos(theta)
    """

    th = np.radians(deg)
    c = np.cos(th)
    s = np.sin(th)

    sx = sign * c**2
    sy = sign * s**2
    sxy = sign * s * c

    return sx, sy, sxy


def planar_stress_state(th):
    """
    sigma_x = cos(th)
    sigma_y = sin(th)
    sigma_xy = 0
    """
    return np.cos(th), np.sin(th), 0.0


# ------------------------------------------------------------
# 8. Prediction functions
# ------------------------------------------------------------
def predict_sigma_uniaxial(raw, deg, sign=+1.0):
    """
    단축 인장 또는 압축 항복응력 크기 예측

    sign = +1 : tensile yield stress
    sign = -1 : compressive yield stress magnitude
    """

    sx, sy, sxy = uniaxial_stress_state(deg, sign=sign)

    phi, _, _, _ = get_phi_and_derivatives(raw, sx, sy, sxy)

    if phi <= 0 or np.isnan(phi):
        return np.nan

    return (phi / k12) ** (-1.0 / 12.0)


def predict_sigma_theta(raw, deg):
    return predict_sigma_uniaxial(raw, deg, sign=+1.0)


def predict_sigma_compression(raw, deg):
    return predict_sigma_uniaxial(raw, deg, sign=-1.0)


def predict_r_theta(raw, deg):
    sx, sy, sxy = uniaxial_stress_state(deg, sign=+1.0)

    _, dfx, dfy, dfxy = get_phi_and_derivatives(raw, sx, sy, sxy)

    th = np.radians(deg)
    c = np.cos(th)
    s = np.sin(th)

    numerator = dfx * s**2 + dfy * c**2 - dfxy * s * c
    denominator = dfx + dfy

    if np.abs(denominator) < 1.0e-14:
        return np.nan

    return -numerator / denominator


def predict_sigma_b(raw):
    """
    등2축 인장 항복응력 sigma_b / sigma_0
    """

    phi, _, _, _ = get_phi_and_derivatives(raw, 1.0, 1.0, 0.0)

    if phi <= 0 or np.isnan(phi):
        return np.nan

    return (phi / k12) ** (-1.0 / 12.0)


def predict_r_b(raw):
    """
    R_b = df/dsigma_y / df/dsigma_x
    """

    _, dfx, dfy, _ = get_phi_and_derivatives(raw, 1.0, 1.0, 0.0)

    if np.abs(dfx) < 1.0e-14:
        return np.nan

    return dfy / dfx

def radial_yield_stress(raw, ang):
    """
    항복곡면의 radial distance rho(theta) = sigma_theta / sigma_0
    """
    sx, sy, sxy = planar_stress_state(ang)
    phi, _, _, _ = get_phi_and_derivatives(raw, sx, sy, sxy)
    if phi <= 0 or np.isnan(phi):
        return np.nan
    return (phi / k12)**(-1.0/12.0)


# ------------------------------------------------------------
# 9. Closure and positivity penalties
# ------------------------------------------------------------
def closure_penalty(raw, n_ang=181, eps=1.0e-8, weight=5.0):
    """
    항복곡면이 열리지 않도록 phi(direction)>0을 요구합니다.

    sx = cos(theta), sy = sin(theta), sxy = 0
    방향들에 대해 phi가 eps보다 작으면 penalty를 줍니다.
    """

    res = []
    angs = np.linspace(0.0, 2.0*np.pi, n_ang, endpoint=False)

    for th in angs:
        sx = np.cos(th)
        sy = np.sin(th)
        sxy = 0.0

        phi, _, _, _ = get_phi_and_derivatives(raw, sx, sy, sxy)

        if np.isnan(phi) or np.isinf(phi):
            res.append(1.0e3)
        elif phi < eps:
            res.append(np.sqrt(weight) * (eps - phi) / eps)
        else:
            res.append(0.0)

    return np.array(res)


def j2_positive_penalty(raw, n_ang=181, eps=1.0e-8, weight=5.0):
    """
    J2^0가 모든 방향에서 양수가 되도록 하는 penalty입니다.
    """

    params = unpack_raw_params(raw)

    res = []
    angs = np.linspace(0.0, 2.0*np.pi, n_ang, endpoint=False)

    # normal stress directions
    for th in angs:
        sx = np.cos(th)
        sy = np.sin(th)
        sxy = 0.0

        j20, _ = get_j2_j3(params, sx, sy, sxy)

        if np.isnan(j20) or np.isinf(j20):
            res.append(1.0e3)
        elif j20 < eps:
            res.append(np.sqrt(weight) * (eps - j20) / eps)
        else:
            res.append(0.0)

    # pure shear direction도 추가
    j20_shear, _ = get_j2_j3(params, 0.0, 0.0, 1.0)

    if np.isnan(j20_shear) or np.isinf(j20_shear):
        res.append(1.0e3)
    elif j20_shear < eps:
        res.append(np.sqrt(weight) * (eps - j20_shear) / eps)
    else:
        res.append(0.0)

    return np.array(res)


def polar_convexity_penalty(raw, n_ang=361, weight=10.0, eps=1.0e-8):
    """
    극좌표 항복곡면 rho(theta)에 대한 볼록성 penalty.

    볼록 조건:
        rho^2 + 2*rho_prime^2 - rho*rho_double_prime >= 0

    이 값이 음수가 되는 구간은 오목부가 생긴 것으로 보고 penalty를 부여합니다.
    """

    angs = np.linspace(0.0, 2.0*np.pi, n_ang, endpoint=False)
    dth = angs[1] - angs[0]

    rho = np.array(
        [radial_yield_stress(raw, th) for th in angs]
    )

    if np.any(np.isnan(rho)) or np.any(np.isinf(rho)):
        return np.ones(n_ang) * 1.0e3

    rho_p = np.roll(rho, -1)
    rho_m = np.roll(rho, 1)

    rho_prime = (rho_p - rho_m) / (2.0*dth)
    rho_double = (rho_p - 2.0*rho + rho_m) / (dth**2)

    curvature_measure = rho**2 + 2.0*rho_prime**2 - rho*rho_double

    # 음수가 되면 오목부 발생
    pen = np.maximum(0.0, -curvature_measure + eps)

    # scale normalization
    scale = np.mean(rho**2) + eps

    return np.sqrt(weight) * pen / scale


# ------------------------------------------------------------
# 10. Objective function
# ------------------------------------------------------------

def yield_locus_residual(raw, locus_points, weight=10.0):
    """
    Additional experimental yield locus points.

    Each point is:
        [sigma_x/sigma_0, sigma_y/sigma_0]

    Yield condition:
        phi(sigma_x, sigma_y, 0) - k12 = 0

    Residual:
       (phi / k12)**(1.0/12.0) - 1.0
    """

    res = []

    for sx, sy in locus_points:
        phi, _, _, _ = get_phi_and_derivatives(raw, sx, sy, 0.0)

        if phi <= 0 or np.isnan(phi) or np.isinf(phi):
            res.append(1.0e3)
        else:
            res.append(np.sqrt(weight) * ((phi / k12)**(1.0/12.0) - 1.0))

    return np.array(res)

def objective(raw):
    """
    실험값 fitting residual + 물리적 제약 penalty
    """

    # fitting weights
    w_sigma = 20.0
    w_r = 1.0
    w_sigma_b = 10.0
    w_r_b = 1.0
    w_comp = 15.0
    w_locus = 15.0


    pred_sigma = np.array([
        predict_sigma_theta(raw, deg) for deg in angles_deg
    ])

    pred_r = np.array([
        predict_r_theta(raw, deg) for deg in angles_deg
    ])

    pred_sb = predict_sigma_b(raw)
    pred_rb = predict_r_b(raw)

    if (
        np.any(np.isnan(pred_sigma))
        or np.any(np.isnan(pred_r))
        or np.isnan(pred_sb)
        or np.isnan(pred_rb)
        or np.any(np.isinf(pred_sigma))
        or np.any(np.isinf(pred_r))
        or np.isinf(pred_sb)
        or np.isinf(pred_rb)
    ):
        return np.ones(2*len(angles_deg) + 2 + 50) * 1.0e6

    res_sigma = np.sqrt(w_sigma) * (1.0 - pred_sigma / exp_sigma)
    res_r = np.sqrt(w_r) * (1.0 - pred_r / exp_r)
    res_sigma_b = np.array([
        np.sqrt(w_sigma_b) * (1.0 - pred_sb / exp_sigma_b)
    ])
    res_r_b = np.array([
        np.sqrt(w_r_b) * (1.0 - pred_rb / exp_r_b)
    ])

    residuals = [
        res_sigma,
        res_r,
        res_sigma_b,
        res_r_b
    ]

    # 압축 데이터가 있으면 추가
    if use_compression_data:
        pred_comp = np.array([
            predict_sigma_compression(raw, deg)
            for deg in comp_angles_deg
        ])

        if np.any(np.isnan(pred_comp)) or np.any(np.isinf(pred_comp)):
            return np.ones(2*len(angles_deg) + 2 + len(comp_angles_deg) + 50) * 1.0e6

        res_comp = np.sqrt(w_comp) * (1.0 - pred_comp / exp_sigma_c)

        residuals.append(res_comp)

    # additional biaxial yield locus data
    if use_locus_data:
        residuals.append(
        yield_locus_residual(raw, exp_locus, weight=w_locus)
        )

    # 닫힌 항복곡면 penalty
    residuals.append(closure_penalty(raw, n_ang=181, eps=1.0e-8, weight=2.0))

    # J2^0 positive penalty
    residuals.append(j2_positive_penalty(raw, n_ang=181, eps=1.0e-8, weight=2.0))

    # smooth convex yield locus
    residuals.append(polar_convexity_penalty(raw, n_ang=361, weight=70.0))


    return np.concatenate(residuals)


