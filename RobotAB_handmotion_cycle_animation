ax.text(0, 2.06, "ASSEMBLY", fontsize=10, color='#27ae60',
        ha='center', fontweight='bold')

# 로봇 아티스트
lnA1, = ax.plot([],[],'o-',lw=5,color='#e74c3c',
                solid_capstyle='round',zorder=4)
lnA2, = ax.plot([],[],'o-',lw=4,color='#f1948a',
                solid_capstyle='round',zorder=4)
grpA, = ax.plot([],[],'o',ms=13,zorder=6,mec='black',mew=0.8)
trA,  = ax.plot([],[],lw=0.8,color='#e74c3c',alpha=0.30)
pdA,  = ax.plot([],[],'s',ms=7,color='#e74c3c',zorder=5,alpha=0)

lnB1, = ax.plot([],[],'o-',lw=5,color='#2980b9',
                solid_capstyle='round',zorder=4)
lnB2, = ax.plot([],[],'o-',lw=4,color='#85c1e9',
                solid_capstyle='round',zorder=4)
grpB, = ax.plot([],[],'o',ms=13,zorder=6,mec='black',mew=0.8)
trB,  = ax.plot([],[],lw=0.8,color='#2980b9',alpha=0.30)
pdB,  = ax.plot([],[],'s',ms=7,color='#2980b9',zorder=5,alpha=0)

stA = ax.text(3.30, 3.30, '', fontsize=8.5, ha='right', va='top',
              color='#c0392b', fontweight='bold', family='monospace',
              bbox=dict(boxstyle='round,pad=0.3',
                        fc='#fff0ed', ec='#e74c3c', lw=1.5))
stB = ax.text(-3.30, 3.30, '', fontsize=8.5, ha='left', va='top',
              color='#1a5276', fontweight='bold', family='monospace',
              bbox=dict(boxstyle='round,pad=0.3',
