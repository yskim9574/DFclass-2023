print(f"\n▶ Rendering {TF} frames ...\n")

ani = FuncAnimation(fig, update, frames=TF,
                    interval=1000//FPS,
                    blit=False, repeat=False)

# ── Step 1: MP4 저장 ────────────────────
FNAME = "dual_robot_assembly_35s.mp4"
try:
    ani.save(FNAME, writer="ffmpeg", fps=FPS, dpi=120,
             extra_args=['-vcodec','libx264','-pix_fmt','yuv420p'])
    fmb = os.path.getsize(FNAME) / (1024*1024)
    print(f"\n{'='*50}")
    print(f"  [OK] MP4: {FNAME}  ({fmb:.1f} MB)")
    print(f"{'='*50}")
except Exception as e:
    print(f"ffmpeg 실패: {e}")
    FNAME = "dual_robot_assembly_35s.gif"
    print("GIF 저장 중...")
    ani.save(FNAME, writer="pillow", fps=FPS, dpi=80)
    fmb = os.path.getsize(FNAME) / (1024*1024)
    print(f"  [OK] GIF: {FNAME}  ({fmb:.1f} MB)")

plt.close(fig)

# ── Step 2: base64 인라인 재생 ──────────
