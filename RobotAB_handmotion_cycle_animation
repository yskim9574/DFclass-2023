# ═══════════════════════════════════
#  IK / FK
# ═══════════════════════════════════
def ik(x, y, bx, by, L1, L2, el="down"):
    dx, dy = x - bx, y - by
    r2 = dx*dx + dy*dy
    c2 = max(-1, min(1, (r2 - L1**2 - L2**2) / (2*L1*L2)))
    t2 = math.acos(c2)
    if el == "up": t2 = -t2
    t1 = math.atan2(dy, dx) - math.atan2(
        L2*math.sin(t2), L1+L2*math.cos(t2))
    return t1, t2

def fk(t1, t2, bx, by, L1, L2):
    x1 = bx + L1*math.cos(t1)
    y1 = by + L1*math.sin(t1)
    x2 = x1 + L2*math.cos(t1+t2)
    y2 = y1 + L2*math.sin(t1+t2)
    return (bx, by), (x1, y1), (x2, y2)

def mv(a, b, n):
    return np.linspace(a, b, n+1)[1:]

# ═══════════════════════════════════
#  로봇 파라미터
# ═══════════════════════════════════
Abx, Aby = 0.0, 0.0
AH = (1.7, 0.0);  AP = (1.5, 0.7);  APL = (0.0, 1.68)
AL1, AL2 = 1.0, 1.5;  AEL = "down";  ASEC = 5.0

Bbx, Bby = -0.4, 0.0
BH = (-2.1, 0.0);  BP = (-1.9, 0.6);  BPL = (0.0, 1.60)
BL1, BL2 = 1.0, 1.2;  BEL = "up";  BSEC = 7.0

# ═══════════════════════════════════
#  타이밍 (20 fps)
# ═══════════════════════════════════
FPS = 20
ANF = [25, 5, 30, 5, 25, 10];  ATOT = 100   # 5s×20
BNF = [30, 5, 43, 6, 40, 16];  BTOT = 140   # 7s×20
PH = ["HOME->PICK","PICK-UP","PICK->PLACE",
      "PLACE","PLACE->HOME","HOME(wait)"]

SIM = 35.0;  TF = int(SIM * FPS)  # 700 frames
NA = 7;  NB = 5

print("=" * 55)
print(f"  {SIM:.0f}s simulation  |  {TF} frames @ {FPS}fps")
print(f"  A: {ASEC:.0f}s × {NA} cycles  starts: "
      + ", ".join(f"{c*ASEC:.0f}s" for c in range(NA)))
print(f"  B: {BSEC:.0f}s × {NB} cycles  starts: "
      + ", ".join(f"{c*BSEC:.0f}s" for c in range(NB)))
print("=" * 55)

# ═══════════════════════════════════
#  궤적 생성
# ═══════════════════════════════════
def build(bx, by, h, p, pl, L1, L2, el, nf):
    th, t2h   = ik(*h,  bx, by, L1, L2, el)
    tp, t2p   = ik(*p,  bx, by, L1, L2, el)
    tl, t2l   = ik(*pl, bx, by, L1, L2, el)
    t1 = np.concatenate([
        mv(th,tp,nf[0]),   np.full(nf[1],tp),
        mv(tp,tl,nf[2]),   np.full(nf[3],tl),
        mv(tl,th,nf[4]),   np.full(nf[5],th)])
    t2 = np.concatenate([
        mv(t2h,t2p,nf[0]), np.full(nf[1],t2p),
        mv(t2p,t2l,nf[2]), np.full(nf[3],t2l),
        mv(t2l,t2h,nf[4]), np.full(nf[5],t2h)])
    gr = ([False]*nf[0] +
          [True]*(nf[1]+nf[2]+nf[3]) +
          [False]*(nf[4]+nf[5]))
    return t1, t2, gr

a1, a2, ag_ = build(Abx,Aby,AH,AP,APL,AL1,AL2,AEL,ANF)
b1, b2, bg_ = build(Bbx,Bby,BH,BP,BPL,BL1,BL2,BEL,BNF)

At1 = np.tile(a1, NA);  At2 = np.tile(a2, NA);  Ag = ag_ * NA
Bt1 = np.tile(b1, NB);  Bt2 = np.tile(b2, NB);  Bg = bg_ * NB
assert len(At1) == TF and len(Bt1) == TF

def gp(ic, nf):
    c = 0
    for n, nm in zip(nf, PH):
        if ic < c + n: return nm
        c += n
    return PH[-1]

