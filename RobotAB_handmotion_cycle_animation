                            fc='#eafaf1', ec='#27ae60', lw=1.2))

# 타임라인
axt.set_xlim(0, SIM);  axt.set_ylim(-0.5, 3.0)
axt.set_yticks([])
axt.set_xlabel("Time (s)", fontsize=8)
axt.set_xticks(range(0, int(SIM)+1, 5))
axt.set_xticks(range(0, int(SIM)+1, 1), minor=True)
axt.tick_params(labelsize=7)
axt.grid(True, axis='x', alpha=0.2, which='minor')
axt.grid(True, axis='x', alpha=0.5, which='major')
axt.set_facecolor('#f8f8f8')

for c in range(NA):
    t0 = c * ASEC
    axt.barh(2.0, ASEC*0.95, left=t0+ASEC*0.025, height=0.55,
             color='#e74c3c', alpha=0.20, ec='#e74c3c', lw=0.8)
    axt.text(t0+ASEC/2, 2.0, f"A#{c+1}", ha='center', va='center',
             fontsize=6.5, fontweight='bold', color='#c0392b')
for c in range(NB):
    t0 = c * BSEC
    axt.barh(0.8, BSEC*0.95, left=t0+BSEC*0.025, height=0.55,
             color='#2980b9', alpha=0.20, ec='#2980b9', lw=0.8)
    axt.text(t0+BSEC/2, 0.8, f"B#{c+1}", ha='center', va='center',
             fontsize=6.5, fontweight='bold', color='#2471a3')
axt.text(-0.3, 2.0, "A", fontsize=9, fontweight='bold',
         color='#e74c3c', va='center')
axt.text(-0.3, 0.8, "B", fontsize=9, fontweight='bold',
         color='#2980b9', va='center')
tlc = axt.axvline(0, color='black', lw=2, zorder=10)

# ═══════════════════════════════════
#  State
# ═══════════════════════════════════
hA = [];  hB = []
cntA = 0;  cntB = 0;  cntAs = 0
pvA = "";  pvB = ""
rdA = False;  rdB = False
fc = 0;  fm = ""

def update(i):
    global cntA, cntB, cntAs, pvA, pvB, rdA, rdB, fc, fm

    t = i / FPS
    iA = i % ATOT;  iB = i % BTOT
    cyA = i // ATOT + 1;  cyB = i // BTOT + 1
    tA = iA / FPS;  tB = iB / FPS
    phA = gp(iA, ANF);  phB = gp(iB, BNF)

    # 플래시
    if iA == 0 and i > 0:
        fc = 17
        fm = f"A CYCLE #{cyA} START! (t={t:.0f}s)"
        fltxt.set_color('#e74c3c')
        fltxt.set_bbox(dict(boxstyle='round,pad=0.5',
                            fc='#fff0ed', ec='#e74c3c', lw=3))
    if iB == 0 and i > 0:
        fc = 17
        fm = f"B CYCLE #{cyB} START! (t={t:.0f}s)"
        fltxt.set_color('#2980b9')
        fltxt.set_bbox(dict(boxstyle='round,pad=0.5',
                            fc='#ebf5fb', ec='#2980b9', lw=3))

    # Robot A
    bA_, j1A_, eA_ = fk(float(At1[i]), float(At2[i]),
                         Abx, Aby, AL1, AL2)
    lnA1.set_data([bA_[0],j1A_[0]], [bA_[1],j1A_[1]])
    lnA2.set_data([j1A_[0],eA_[0]], [j1A_[1],eA_[1]])
    grpA.set_data([eA_[0]], [eA_[1]])
    grpA.set_color('#e74c3c' if Ag[i] else '#ccc')
    hA.append(eA_)
    if len(hA) > 100: hA.pop(0)
    xa, ya = zip(*hA);  trA.set_data(xa, ya)
    if Ag[i]:
        pdA.set_data([eA_[0]], [eA_[1]-0.12])
        pdA.set_alpha(0.85)
    else:
        pdA.set_alpha(0)

    # Robot B
    bB_, j1B_, eB_ = fk(float(Bt1[i]), float(Bt2[i]),
                         Bbx, Bby, BL1, BL2)
    lnB1.set_data([bB_[0],j1B_[0]], [bB_[1],j1B_[1]])
    lnB2.set_data([j1B_[0],eB_[0]], [j1B_[1],eB_[1]])
    grpB.set_data([eB_[0]], [eB_[1]])
    grpB.set_color('#2980b9' if Bg[i] else '#ccc')
    hB.append(eB_)
    if len(hB) > 140: hB.pop(0)
    xb, yb = zip(*hB);  trB.set_data(xb, yb)
    if Bg[i]:
        pdB.set_data([eB_[0]], [eB_[1]-0.12])
        pdB.set_alpha(0.85)
    else:
        pdB.set_alpha(0)

    # Place 감지
    if pvA == "PLACE" and phA != "PLACE":
        cntA += 1;  rdA = True
    if pvB == "PLACE" and phB != "PLACE":
        cntB += 1;  rdB = True
    if rdA and rdB:
        cntAs += 1;  rdA = False;  rdB = False
    pvA = phA;  pvB = phB

    # 텍스트 갱신
    ax.set_title(
        f"Time: {t:.1f}s / {SIM:.0f}s   |   "
        f"A: cycle #{cyA} ({tA:.1f}/{ASEC:.0f}s)   |   "
        f"B: cycle #{cyB} ({tB:.1f}/{BSEC:.0f}s)",
        fontsize=9.5, fontweight='bold', pad=6)

    stA.set_text(
        f"Robot A (5s)\n"
        f"Cycle #{cyA} [{tA:.1f}/{ASEC:.0f}s]\n"
        f"{phA}\n"
        f"EE({eA_[0]:+.2f},{eA_[1]:+.2f})\n"
        f"{'HOLD' if Ag[i] else 'OPEN'}  Place:{cntA}")
    stB.set_text(
        f"Robot B (7s)\n"
        f"Cycle #{cyB} [{tB:.1f}/{BSEC:.0f}s]\n"
        f"{phB}\n"
        f"EE({eB_[0]:+.2f},{eB_[1]:+.2f})\n"
        f"{'HOLD' if Bg[i] else 'OPEN'}  Place:{cntB}")

    if fc > 0:
        fltxt.set_text(fm)
        fltxt.set_alpha(min(1, fc / 8))
        fc -= 1
    else:
        fltxt.set_alpha(0)

    wA = "Rdy" if rdA else "wait"
    wB = "Rdy" if rdB else "wait"
    asytxt.set_text(
        f"Assembly: {cntAs}  |  "
        f"A placed:{cntA}({wA})  B placed:{cntB}({wB})")

    tlc.set_xdata([t])

    # 진행 상황 출력
    if i % 100 == 0:
        print(f"  frame {i:4d}/{TF}  t={t:.1f}s  "
              f"A:cyc#{cyA} B:cyc#{cyB}")

