# =========================================================
# 8. Interpolate joint path
# =========================================================
def interpolate_joint_path(q_list, n_per_segment=25):
    frames = []
    for i in range(len(q_list) - 1):
        q0 = q_list[i]
        q1 = q_list[i + 1]
        dq = wrap_to_pi(q1 - q0)
        for t in np.linspace(0, 1, n_per_segment, endpoint=False):
            qt = wrap_to_pi(q0 + t * dq)
            frames.append(qt)
    frames.append(q_list[-1])
    return frames

