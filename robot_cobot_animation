    tr = np.array(trace_xyz)

    tcp_trace.set_data(tr[:, 0], tr[:, 1])
    tcp_trace.set_3d_properties(tr[:, 2])

    ax.view_init(elev=24, azim=40 + 0.1 * frame_idx)
    return robot_line, tcp_trace

