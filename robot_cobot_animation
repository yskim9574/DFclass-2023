# =========================================================
# 3. Rotation vector -> rotation matrix
# =========================================================
def rotvec_to_R(rx, ry, rz):
    r = np.array([rx, ry, rz], dtype=float)
    theta = np.linalg.norm(r)
    if theta < 1e-12:
        return np.eye(3)

    u = r / theta
    ux, uy, uz = u

    K = np.array([
        [0,   -uz,  uy],
        [uz,   0,  -ux],
        [-uy, ux,   0]
    ], dtype=float)

    R = np.eye(3) + np.sin(theta) * K + (1 - np.cos(theta)) * (K @ K)
    return R

def pose_to_T(pose):
    px, py, pz, rx, ry, rz = pose
    T = np.eye(4)
    T[:3, :3] = rotvec_to_R(rx, ry, rz)
    T[:3, 3] = [px, py, pz]
    return T

# =========================================================
# 4. Standard D-H transform
# =========================================================
def dh(a, alpha, d, theta):
    c = np.cos(theta)
    s = np.sin(theta)
    ca = np.cos(alpha)
    sa = np.sin(alpha)

    return np.array([
        [c, -s*ca,  s*sa, a*c],
        [s,  c*ca, -c*sa, a*s],
        [0,    sa,    ca,   d],
        [0,     0,     0,   1]
    ], dtype=float)

# =========================================================
# 5. Forward kinematics
# =========================================================
def fk_ur5e(q):
    q1, q2, q3, q4, q5, q6 = q

    A1 = dh(0,        np.pi/2, d1, q1)
    A2 = dh(a2,       0,       0,  q2)
    A3 = dh(a3,       0,       0,  q3)
    A4 = dh(0,        np.pi/2, d4, q4)
    A5 = dh(0,       -np.pi/2, d5, q5)
    A6 = dh(0,        0,       d6, q6)

    T = np.eye(4)
    Ts = [T.copy()]
    for A in [A1, A2, A3, A4, A5, A6]:
        T = T @ A
        Ts.append(T.copy())

    return Ts[-1], Ts

def joint_positions(q):
    _, Ts = fk_ur5e(q)
    pts = np.array([T[:3, 3] for T in Ts], dtype=float)  # 7 points
    return pts

# =========================================================
# 6. Numerical IK
# =========================================================
def wrap_to_pi(x):
    return (x + np.pi) % (2*np.pi) - np.pi

def pose_error(q, T_target, w_pos=1.0, w_rot=120.0):
    T_now, _ = fk_ur5e(q)
    p_now = T_now[:3, 3]
    p_tar = T_target[:3, 3]

    R_now = T_now[:3, :3]
    R_tar = T_target[:3, :3]

    R_err = R_tar.T @ R_now
    e_rot = 0.5 * np.array([
        R_err[2, 1] - R_err[1, 2],
        R_err[0, 2] - R_err[2, 0],
        R_err[1, 0] - R_err[0, 1]
    ])

    e_pos = p_now - p_tar
    return np.hstack([w_pos * e_pos, w_rot * e_rot])

def numerical_jacobian(fun, q, eps=1e-6):
    f0 = fun(q)
    J = np.zeros((len(f0), len(q)))
    for i in range(len(q)):
        dq = np.zeros_like(q)
        dq[i] = eps
        fp = fun(q + dq)
        fm = fun(q - dq)
        J[:, i] = (fp - fm) / (2 * eps)
    return J

def ik_solve(T_target, q0=None, max_iter=120, lam=1e-2):
    if q0 is None:
        q = np.zeros(6, dtype=float)
    else:
        q = np.array(q0, dtype=float)

    for _ in range(max_iter):
        e = pose_error(q, T_target)
        if np.linalg.norm(e[:3]) < 1e-3 and np.linalg.norm(e[3:]) < 1e-3:
            break

        J = numerical_jacobian(lambda x: pose_error(x, T_target), q)
        H = J.T @ J + (lam**2) * np.eye(6)
        g = J.T @ e
        dq = -np.linalg.solve(H, g)

        step = 1.0
        improved = False
        current_norm = np.linalg.norm(e)

        for _ in range(12):
            q_try = wrap_to_pi(q + step * dq)
            e_try = pose_error(q_try, T_target)
            if np.linalg.norm(e_try) < current_norm:
                q = q_try
                improved = True
                break
            step *= 0.5

        if not improved:
            q = wrap_to_pi(q + 0.1 * dq)

    return wrap_to_pi(q)

